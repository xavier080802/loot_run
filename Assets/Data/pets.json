/* PetData Object format:

    NOTES:
    
    value: For multiplicative, note that 1 means 1% of the stat
    mathType: Flat=0, Multiplicative/mult=1. If flat, stat doesnt really matter. Can use string(case insensitive) or int
    stat: STAT_TYPE enum in StatsType.h, start from 0 or use string(case insensitive)
    rarityScaling: Multiplied with the base values of passive/multipliers for each rarity, starting from COMMON
    dmgTypes: phy/mag/ele/true. Can write longer but these are the minimum strings to parse. (case insensitive)
    effects: Status Effects (see far below for format) array.

    Arrays can be omitted if empty, PetManager will check if the array exists
    ------------------------------------------------------------

    {
        "id": 0, // Corresponding to PET_TYPE
        "name": "",
        "passive": [ // Array, each entry is a Mod
            {
                "value": 0,
                "mathType": 1,
                "stat": 1
            }
        ],
        "multipliers": [ // Array, each entry is a Mod used to calc skill multipliers. Dev handles which index is for what.
            {
                "value": 0,
                "mathType": 1,
                "stat": 1
            }
        ],
        "dmgTypes": [] // DAMAGE_TYPES array. Dev handles which index is for what. Default (if omitted) is Magical
        "effects: [] //OPTIONAL extra status effects
        "rarityScaling": [ 1, 2, 3, 4, 5, 6 ], // Must have 6 entries, 1 for each rarity. COMMON first, to LEGENDARY
        "skillCooldown": 0,
        "skillDesc": "",
        "skillElements": [ ], //Elements the skill may inflict. ELEMENT_TYPE
        "texture": [""], // Array of Filepath to texture
        "extra": {} //OPTIONAL Object with whatever keys and STRING values
    }

    ------------------------------------------------------------

    Status effect format:

    {
        "name": "",
        "duration": 5,      // Omit/-1 for permanent
        "maxStacks": 1,     // Omit for default 1
        "startStacks": 1,   // Omit for default 1. Number of stacks for first application
        "icon": "Assets/",  // Omit for default. Texture path for icon
        "type": "",         // "buff" / "debuff" / omit for NONE. (case insensitive)
        "mods": []          // Stat changes. Follow Mod format of value, mathType, stat
    }

*/

