                        "contentPos": [ 0, 300 ],
                        "contentWidth": 0,
                        "contentFontSize": 0.5,
                        "contentLineSpace": 0.015,
                        "imgPaths": []
                    },
                    // ============ BLOOD =============
                    {
                        "text": "Blood",
                        "contentTxtOrigin": "TEXT_MIDDLE",
                        "contentCol": [ 255, 200, 200, 255 ],
                        "contentPos": [ -500, 200 ],
                        "contentWidth": 350,
                        "contentFontSize": 0.5,
                        "contentLineSpace": 0.015,
                        "imgPaths": [
                            {
                                "path": "Assets/bloodEle.png",
                                "size": [ 100, 100 ],
                                "pos": [ -500, 100 ]
                            }
                        ]
                    },
                    {
                        "text": "While applied, deals damage-over-time (DoT) to its bearer.\n\nReapplying this element triggers 1 instance of the DoT immediately.",
                        "contentTxtOrigin": "TEXT_MIDDLE",
                        "contentCol": [ 255, 255, 255, 255 ],
                        "contentPos": [ -500, 40 ],
                        "contentWidth": 350,
                        "contentFontSize": 0.5,
                        "contentLineSpace": 0.015,
                        "imgPaths": []
                    },
