                    {
                        "text": "Sun",
                        "contentTxtOrigin": "TEXT_MIDDLE",
                        "contentCol": [ 255, 255, 200, 255 ],
                        "contentPos": [ 0, 200 ],
                        "contentWidth": 350,
                        "contentFontSize": 0.5,
                        "contentLineSpace": 0.015,
                        "imgPaths": [
                            {
                                "path": "Assets/sunEle.png",
                                "size": [ 100, 100 ],
                                "pos": [ 0, 100 ]
                            }
                        ]
                    },
                    {
                        "text": "When applied, it has a certain number of stacks.\n\nEach time the bearer is hit, the attacker removes 1 stack off the bearer to gain an equal number of stacks of a buff.\n\nAll remaining stacks are transferred to the killer on-death",
                        "contentTxtOrigin": "TEXT_MIDDLE",
                        "contentCol": [ 255, 255, 255, 255 ],
                        "contentPos": [ 0, 40 ],
                        "contentWidth": 350,
                        "contentFontSize": 0.5,
                        "contentLineSpace": 0.015,
                        "imgPaths": []
                    },
